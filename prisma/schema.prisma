generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Rol {
  MESA_CONTROL
  DEPENDENCIA
  JEFE_CUADRILLA
}

model Ciudadano {
  id        String    @id @default(cuid())
  nombre    String
  telefono  String    @unique
  createdAt DateTime  @default(now())
  reportes  Reporte[]
}

model Dependencia {
  id       String            @id @default(cuid())
  nombre   String            @unique
  slug     String            @unique
  usuarios Usuario[]
  jefes    JefeDeCuadrilla[]
  reportes Reporte[]
}

model Usuario {
  id              String           @id @default(cuid())
  nombre          String
  email           String           @unique
  passwordHash    String
  rol             Rol
  dependenciaId   String?
  dependencia     Dependencia?     @relation(fields: [dependenciaId], references: [id])
  jefeDeCuadrilla JefeDeCuadrilla?
  createdAt       DateTime         @default(now())
}

model JefeDeCuadrilla {
  id            String              @id @default(cuid())
  usuarioId     String              @unique
  usuario       Usuario             @relation(fields: [usuarioId], references: [id])
  dependenciaId String
  dependencia   Dependencia         @relation(fields: [dependenciaId], references: [id])
  asignaciones  AsignacionReporte[]
}

model AsignacionReporte {
  id              String          @id @default(cuid())
  reporteId       String          @unique
  reporte         Reporte         @relation(fields: [reporteId], references: [id], onDelete: Cascade)
  jefeCuadrillaId String
  jefeCuadrilla   JefeDeCuadrilla @relation(fields: [jefeCuadrillaId], references: [id])
  nota            String          @default("")
  createdAt       DateTime        @default(now())
}

model Reporte {
  id               String              @id @default(cuid())
  clientRequestId  String              @unique
  folio            String              @unique
  tipo             String
  descripcion      String
  referencia       String
  colonia          String
  direccion        String
  lat              Float?
  lng              Float?
  estatus          String              @default("creado")
  dependencia      String              @default("Sin asignar")
  dependenciaId    String?
  dependenciaRel   Dependencia?        @relation(fields: [dependenciaId], references: [id])
  ciudadanoId      String
  ciudadano        Ciudadano           @relation(fields: [ciudadanoId], references: [id])
  ciudadanoNombre  String
  fotoUrl          String?
  createdAt        DateTime            @default(now())
  historial        HistorialEstatus[]
  evaluacion       Evaluacion?
  asignacion       AsignacionReporte?
}

model HistorialEstatus {
  id          String   @id @default(cuid())
  reporteId   String
  reporte     Reporte  @relation(fields: [reporteId], references: [id], onDelete: Cascade)
  estatus     String
  nota        String
  dependencia String?
  actor       String?
  createdAt   DateTime @default(now())
}

model Evaluacion {
  id         String   @id @default(cuid())
  reporteId  String   @unique
  reporte    Reporte  @relation(fields: [reporteId], references: [id], onDelete: Cascade)
  estrellas  Int
  comentario String   @default("")
  createdAt  DateTime @default(now())
}

model PushSubscription {
  id        String   @id @default(cuid())
  telefono  String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

model OtpCode {
  telefono  String   @id
  codigo    String
  expiresAt DateTime
  createdAt DateTime @default(now())
}
